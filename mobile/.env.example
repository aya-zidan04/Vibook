# Copy to `.env` (not committed). Expo injects `EXPO_PUBLIC_*` at bundle time.
#
# Templates: .env.lan.example | .env.tunnel.example | .env.production.example
# Full guide: docs/REMOTE_ACCESS.md
#
# Use your laptop's LAN IP — works for physical phone AND local simulator on the same machine.
# Do NOT use localhost or 127.0.0.1 (phones cannot reach your laptop that way).
#
# macOS:   ipconfig getifaddr en0
# Windows: ipconfig → IPv4 under your active Wi‑Fi adapter
#
# After changing this file, restart Expo with a clean cache:
#   npx expo start -c
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8080/api/v1
