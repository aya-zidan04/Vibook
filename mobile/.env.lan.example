# Same Wi‑Fi / LAN — copy to `.env` when phone and laptop share one network.
#
#   cp .env.lan.example .env
#
# Find your laptop IP:
#   macOS:   ipconfig getifaddr en0
#   Windows: ipconfig → IPv4 on active Wi‑Fi adapter
#
# Do NOT use localhost or 127.0.0.1 on a physical phone.
# After editing, restart Expo with cache clear:
#   npx expo start -c
#
# Test from phone browser:
#   http://YOUR_LAN_IP:8080/api/v1/categories
#
# See docs/REMOTE_ACCESS.md for full instructions.

EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8080/api/v1
