{
  "expo": {
    "name": "Vibook",
    "slug": "vibook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vibook-logo-mark.png",
    "scheme": "vibook",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/vibook-logo-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0D14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibook.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["mailto"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/vibook-logo-mark.png",
        "backgroundColor": "#0A0D14"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.vibook.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibook uses your photos to set your business banner and logo.",
          "cameraPermission": "Vibook can use the camera if you take a new photo for your business profile."
        }
      ]
    ]
  }
}
