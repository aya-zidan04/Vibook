# ngrok / HTTPS tunnel — copy to `.env` for mobile data or remote Wi‑Fi testing.
#
#   cp .env.tunnel.example .env
#
# 1. Start backend:  cd backend && mvn spring-boot:run
# 2. Start tunnel:   ngrok http 8080
# 3. Paste the HTTPS forwarding host below (include /api/v1).
# 4. Restart Expo:   npx expo start -c
#
# Test from phone browser:
#   https://YOUR_SUBDOMAIN.ngrok-free.app/api/v1/categories
#
# Free ngrok URLs change when ngrok restarts — update .env and expo start -c again.
# See docs/REMOTE_ACCESS.md for CORS notes (admin-web) and limitations.

EXPO_PUBLIC_API_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api/v1
