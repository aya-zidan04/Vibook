# Production / public API — copy to `.env` when backend is deployed with HTTPS.
#
#   cp .env.production.example .env
#
# Requirements:
#   - Stable public domain (VPS, Railway, Render, etc.)
#   - HTTPS (recommended; required for iOS release without ATS exceptions)
#   - JWT_SECRET and DB_* set on the server (see backend/.env.example)
#
# For EAS/production builds, set EXPO_PUBLIC_API_URL in the build environment
# before building so the URL is baked into the app binary.
#
# Test from phone browser:
#   https://api.yourdomain.com/api/v1/categories
#
# See docs/REMOTE_ACCESS.md for deployment checklist.

EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
